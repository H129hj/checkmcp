# Front CheckMCP.
# Moteur d'audit (server-side) ; le navigateur appelle /api/* en same-origin (proxy nginx).
CHECKMCP_API=http://127.0.0.1:8799
# Postgres local : auth, sessions, monitors privés, historique d'audits, clés API.
DATABASE_URL=postgresql://checkmcp:PASSWORD@127.0.0.1:5432/checkmcp
NEXT_TELEMETRY_DISABLED=1
